# aigate config — copy to .env

# Bearer token that gates the API + dashboard (generate a long random string)
AIGATE_TOKEN=change-me-to-a-long-random-string

# 32-byte hex key for AES-256-GCM encryption of stored account tokens at rest.
# Generate: openssl rand -hex 32
AIGATE_ENCRYPTION_KEY=

# HTTP listen port + host
PORT=20200
HOST=0.0.0.0

# SQLite path
AIGATE_DB=./data/aigate.db

# Selection: skip any account whose worst-window usage % is >= this (0-100)
AIGATE_HEADROOM_CUTOFF=95

# Optional network gate (defense-in-depth under the bearer token).
# Comma-separated LIST — mix CIDR subnets AND single IPs freely.
# A bare IP (no /) = that one host (/32). Empty = allow all. Loopback always OK.
# Behind a reverse proxy, this trusts X-Forwarded-For (set by the proxy).
#   e.g. the whole LAN + one external box (a remote Pi):
AIGATE_ALLOW_CIDR=192.168.1.0/24,68.185.216.174
