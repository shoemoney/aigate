# aigate config — copy to .env

# shared bearer clients send as Authorization: Bearer — generate: openssl rand -hex 24
AIGATE_TOKEN=

# 32-byte hex key for AES-256-GCM encryption of stored account tokens at rest.
# Generate: openssl rand -hex 32
AIGATE_ENCRYPTION_KEY=

# HTTP listen port + host
PORT=20200
HOST=0.0.0.0

# SQLite path
AIGATE_DB=./data/aigate.db

# Selection: skip any account whose worst-window usage % is >= this (0-100)
AIGATE_HEADROOM_CUTOFF=95

# Usage-poll interval in ms (reads Anthropic rate-limit headroom). 0 disables the poller.
AIGATE_POLL_MS=600000

# Self-heal watchdog: every N ms the daemon pings its own DB; if it's wedged
# the process exits non-zero so the supervisor (docker restart / launchd)
# restarts a fresh one. 0 disables. Default 30000 (30s).
AIGATE_WATCHDOG_MS=30000

# Optional network gate (defense-in-depth under the bearer token).
# Comma-separated LIST — mix CIDR subnets AND single IPs freely.
# A bare IP (no /) = that one host (/32). Empty = allow all. Loopback always OK.
#   e.g. the whole LAN + one external box (a remote Pi):
AIGATE_ALLOW_CIDR=192.168.1.0/24,68.185.216.174

# Trust X-Forwarded-For for the real client IP (network gate + audit logs).
# OFF by default so a DIRECT client can't spoof its source IP past the gate.
# Set to 1 ONLY when aigate sits behind a reverse proxy YOU control (e.g. NPM).
# aigate reads the RIGHTMOST XFF hop (the one your proxy appends), so a
# client-prepended spoof is ignored.
AIGATE_TRUST_PROXY=0

# Optional: only honor X-Forwarded-For when the socket peer is one of these proxy
# IPs (comma-separated). Defense-in-depth on top of TRUST_PROXY. Empty = honor XFF
# from any peer (fine when the port isn't reachable except via the proxy).
AIGATE_TRUSTED_PROXIES=

# Provider-key liveness poll interval in ms (GET <base>/models per oaiCompat key;
# flips 401/403 → status='dead'). 0 disables. Default 3600000 (1h).
AIGATE_KEY_POLL_MS=3600000

# Optional outbound alert webhook (Slack/Discord/generic, receives {text,...} JSON).
# Fires on: 0 selectable accounts (outage), a provider key going dead, a failed
# backup. Empty = disabled.
AIGATE_ALERT_WEBHOOK=

# Auth-failure throttle: after MAX_FAILS bad bearers from one IP within WINDOW_MS,
# lock that IP for LOCK_MS (429). Loopback is exempt.
AIGATE_AUTH_MAX_FAILS=10
AIGATE_AUTH_WINDOW_MS=60000
AIGATE_AUTH_LOCK_MS=300000

# Optional: override the served version string (fleet tar-path deploy stamps the sha).
# Falls back to package.json semver when unset.
AIGATE_VERSION=
